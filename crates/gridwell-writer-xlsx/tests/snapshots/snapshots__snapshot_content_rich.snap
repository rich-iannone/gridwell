<sheetData>
<row r="1"><c r="A1" t="inlineStr" s="1"><is><t>Label</t></is></c><c r="B1" t="inlineStr" s="1"><is><t>Content</t></is></c></row>
<row r="2"><c r="A2" t="inlineStr"><is><t>Rich content</t></is></c><c r="B2" t="inlineStr"><is><t>Normal text, bold text second line with *</t></is></c></row>
<row r="3"><c r="A3" t="inlineStr"><is><t>Image cell</t></is></c><c r="B3" t="inlineStr"><is><t>Trend: sparkline</t></is></c></row>
<row r="5"><c r="A5" t="inlineStr"><is><t>* Estimated value.</t></is></c></row>
</sheetData>
